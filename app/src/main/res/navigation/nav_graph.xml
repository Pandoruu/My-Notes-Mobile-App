<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- LoginFragment -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.mynotes.view.ui.auth.LoginFragment"
        android:label="LoginFragment">

        <argument
            android:name="username"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="password"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_loginFragment_to_notesNav"
            app:destination="@id/notesNav" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <!-- RegisterFragment -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.mynotes.view.ui.auth.RegisterFragment"
        android:label="RegisterFragment">

        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- NotesFragment -->
    <fragment
        android:id="@+id/notesNav"
        android:name="com.example.mynotes.view.ui.home.NotesFragment"
        android:label="NotesFragment">

        <action
            android:id="@+id/action_notesNav_to_accountFragment"
            app:destination="@id/accountFragment" />
        <action
            android:id="@+id/action_notesNav_to_viewNoteFragment"
            app:destination="@id/viewNoteFragment" />
        <action
            android:id="@+id/action_notesNav_to_trashFragment"
            app:destination="@id/trashFragment" />
        <action
            android:id="@+id/action_notesNav_to_favoriteFragment"
            app:destination="@id/favoriteFragment" />
        <action
            android:id="@+id/action_notesNav_to_categoryFragment"
            app:destination="@id/categoryFragment" />
        <action
            android:id="@+id/action_notesNav_to_searchNav"
            app:destination="@id/searchNav" />
    </fragment>

    <!-- CalendarFragment -->
    <fragment
        android:id="@+id/calendarNav"
        android:name="com.example.mynotes.view.ui.calendar.CalendarFragment"
        android:label="CalendarFragment" />

    <!-- SearchFragment -->
    <fragment
        android:id="@+id/searchNav"
        android:name="com.example.mynotes.view.ui.search.SearchFragment"
        android:label="SearchFragment">

        <action
            android:id="@+id/action_searchNav_to_viewNoteFragment"
            app:destination="@id/viewNoteFragment" />
    </fragment>

    <!-- ViewNoteFragment -->
    <fragment
        android:id="@+id/viewNoteFragment"
        android:name="com.example.mynotes.view.ui.view_note.ViewNoteFragment"
        android:label="ViewNoteFragment">

        <argument
            android:name="noteId"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/favoriteFragment"
        android:name="com.example.mynotes.view.ui.favorite.FavoriteFragment"
        android:label="FavoriteFragment">

        <action
            android:id="@+id/action_favoriteFragment_to_viewNoteFragment"
            app:destination="@id/viewNoteFragment" />
    </fragment>
    <fragment
        android:id="@+id/trashFragment"
        android:name="com.example.mynotes.view.ui.trash.TrashFragment"
        android:label="TrashFragment" />
    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.example.mynotes.view.ui.category.CategoryFragment"
        android:label="CategoryFragment" />
    <fragment
        android:id="@+id/accountFragment"
        android:name="com.example.mynotes.view.ui.account.AccountFragment"
        android:label="AccountFragment" />
</navigation>
